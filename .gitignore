# ── AI SOC Analyzer — .gitignore ────────────────────────────────

# Real credentials — never commit. Copy soc/secrets.example.py to
# soc/secrets.py and fill in your real values there.
soc/secrets.py

# SQLite database (contains your network topology — keep private)
soc_database.db
*.db
*.db-shm
*.db-wal

# Legacy JSON device store
known_devices.json

# Generated reports (can be large; contain sensitive network data)
reports/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Environment / secrets files (if you ever externalize config further)
.env
config_local.py

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs (if you add file logging later)
*.log
